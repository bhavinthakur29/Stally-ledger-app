{
  "expo": {
    "name": "TekTally",
    "slug": "tektally",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tektally",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "TekTally needs access to your photos to attach receipt images to transactions.",
        "NSCameraUsageDescription": "TekTally needs camera access to capture receipt photos for transactions."
      }
    },
    "android": {
      "package": "com.teksquad.tektally",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow TekTally to attach receipts from your library.",
          "cameraPermission": "Allow TekTally to capture receipt photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#D97706",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "TekTally uses Face ID to unlock your financial ledger when you return to the app."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "firebase": {
        "apiKey": "AIzaSyDVXnSTHY3JZuX9XoVrdhfW32Vx4-okvo4",
        "authDomain": "stally-v1.firebaseapp.com",
        "projectId": "stally-v1",
        "storageBucket": "stally-v1.firebasestorage.app",
        "messagingSenderId": "537805896833",
        "appId": "1:537805896833:web:27d90e20745d07c7296180"
      },
      "router": {},
      "eas": {
        "projectId": "200290ef-af01-4c48-a611-82bc44a61733"
      }
    },
    "owner": "teksquad"
  }
}